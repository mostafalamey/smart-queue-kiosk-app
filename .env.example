# Kiosk App — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
#
# DEVELOPMENT: place .env in the project root (next to package.json).
#
# PRODUCTION (packaged .exe):
#   Place this .env file in the same folder as Smart-Queue-Kiosk-Setup.exe
#   or beside Smart Queue Kiosk.exe in the installed app directory.
#   The app looks there first before falling back to the working directory.
#
# For LAN multi-PC testing:
#   1. Find the backend server's LAN IP (run `ipconfig` on the server machine).
#   2. Set API_BASE_URL to http://<server-lan-ip>:3000
#
# For production with a reserved server IP:
#   Use the router's DHCP reservation (bind server MAC -> fixed IP).
#   Only the backend server needs a fixed/reserved IP.
#
# Example: API_BASE_URL=http://192.168.1.100:3000
API_BASE_URL=http://localhost:3000
