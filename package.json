{
  "name": "smart-queue-kiosk-app",
  "version": "0.1.0",
  "private": true,
  "author": "Mostafa Lamey",
  "description": "Smart Queue Kiosk (Electron-wrapped web app)",
  "main": "src/main.js",
  "scripts": {
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "build:web": "vite build",
    "icons:build": "node scripts/generate-icon-pack.mjs",
    "start": "electron .",
    "pack": "npm run icons:build && npm run build:web && electron-builder --dir",
    "dist": "npm run icons:build && npm run build:web && electron-builder",
    "dist:win": "npm run icons:build && npm run build:web && electron-builder --win nsis"
  },
  "dependencies": {
    "lucide-react": "^0.575.0",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^37.2.3",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.3",
    "to-ico": "^1.1.5",
    "vite": "^5.4.19",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.mlextensions.smartqueue.kiosk",
    "productName": "Smart Queue Kiosk",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Smart Queue Kiosk",
      "artifactName": "Smart-Queue-Kiosk-Setup-${version}.${ext}"
    }
  }
}
